// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CANDIDATE)
  createdAt    DateTime @default(now())

  candidateSessions    Session[]      @relation("CandidateSessions")
  interviewerSessions  Session[]      @relation("InterviewerSessions")
  refreshTokens        RefreshToken[]
}

enum Role {
  CANDIDATE
  INTERVIEWER
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
}

model Session {
  id        String        @id @default(uuid())
  roomCode  String        @unique @default(uuid())
  status    SessionStatus @default(WAITING)
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime      @default(now())

  candidate    User?   @relation("CandidateSessions", fields: [candidateId], references: [id])
  candidateId  String?

  interviewer   User?   @relation("InterviewerSessions", fields: [interviewerId], references: [id])
  interviewerId String?

  // A room (parent) session is created by an interviewer and holds the roomCode.
  // Each candidate who joins gets their own child session (own transcript/eval)
  // linked back to the room via parentId.
  parent   Session?  @relation("RoomChildren", fields: [parentId], references: [id])
  parentId String?
  children Session[] @relation("RoomChildren")

  messages    Message[]
  submissions CodeSubmission[]
  evaluation  Evaluation?
}

enum SessionStatus {
  WAITING
  ACTIVE
  COMPLETED
  ABANDONED
}

model Message {
  id        String      @id @default(uuid())
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())

  session   Session @relation(fields: [sessionId], references: [id])
  sessionId String
}

enum MessageRole {
  USER
  ASSISTANT
}

model CodeSubmission {
  id          String   @id @default(uuid())
  language    String
  code        String
  result      Json?
  submittedAt DateTime @default(now())

  session   Session @relation(fields: [sessionId], references: [id])
  sessionId String
}

model Evaluation {
  id        String   @id @default(uuid())
  score     Int
  feedback  String
  metrics   Json
  createdAt DateTime @default(now())

  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String  @unique
}